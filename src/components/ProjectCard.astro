---
interface Props {
    mediaPath: string;
    title: string;
    description: string;
}

const { mediaPath, title, description } = Astro.props;
const isVideo = /\.(mp4|webm|ogg|mov|m4v)$/i.test(mediaPath);
---

<article
    class="overflow-hidden rounded-2xl border border-[color:var(--color-accent-light)] border-1 bg-slate-900/40 transition-[border-width,box-shadow] duration-200 hover:border-2 hover:shadow-[0_0_24px_rgba(169,214,229,0.35)]"
>
    <div class="grid grid-cols-1 md:grid-cols-3 items-start p-3">
        <div class="hidden sm:block w-full md:col-span-1">
            {
                isVideo ? (
                    <div class="w-full overflow-hidden rounded-2xl aspect-video">
                        <video autoplay loop muted playsinline preload="metadata" class="block h-full w-full object-cover">
                            <source src={mediaPath} type="video/mp4" />
                            Your browser does not support the video tag.
                        </video>
                    </div>
                ) : (
                    <div class="w-full overflow-hidden rounded-2xl aspect-video">
                        <img src={mediaPath} alt={title} loading="lazy" class="block h-full w-full object-cover" />
                    </div>
                )
            }
        </div>

        <div class="p-5 md:p-6 text-left md:col-span-2">
            <h2 class="text-xl font-semibold text-slate-100">{title}</h2>
            <p class="mt-2 leading-7 text-slate-300">{description}</p>
        </div>
    </div>
</article>
