---
const pathname = Astro.url.pathname;

const links = [
    {
        label: "Home",
        href: "/",
        isActive: pathname === "/",
    },
    {
        label: "Projects",
        href: "/projects",
        isActive: pathname.startsWith("/projects"),
    },
];
---

<header class="sticky top-0 z-50 border-b border-slate-800/80 bg-rich-black/85 backdrop-blur">
    <nav class="mx-auto w-full max-w-6xl px-4 py-3">
        <ul class="flex items-center gap-1">
            {
                links.map((link) => (
                    <li>
                        <a
                            href={link.href}
                            aria-current={link.isActive ? "page" : undefined}
                            class:list={[
                                "inline-flex rounded-md px-4 py-2 text-sm font-medium transition-colors",
                                "hover:bg-slate-800/80 hover:text-slate-100",
                                link.isActive
                                    ? "text-[var(--color-accent-light)] underline underline-offset-4 decoration-[var(--color-accent-light)]"
                                    : "text-slate-300",
                            ]}
                        >
                            {link.label}
                        </a>
                    </li>
                ))
            }
        </ul>
    </nav>
</header>
