---
import BaseLayout from "./BaseLayout.astro";

interface Props {
    pageTitle: string;
    title?: string;
    description?: string;
    breadcrumbLabel?: string;
    breadcrumbHref?: string;
    pathLabel?: string;
    subtitle?: string;
    intro?: string;
    codeHref?: string;
    codeLabel?: string;
}

const {
    pageTitle,
    title = `${pageTitle} | Iordanis Antypas`,
    description = "",
    breadcrumbLabel = "Projects",
    breadcrumbHref = "/projects",
    pathLabel = pageTitle,
    subtitle,
    intro,
    codeHref,
    codeLabel = "View Code",
} = Astro.props;
---

<BaseLayout title={title} description={description}>
    <article class="mx-auto w-full max-w-4xl space-y-14 py-12">
        <header class="space-y-5">
            <p class="text-sm uppercase tracking-[0.12em] text-slate-400">
                <a href={breadcrumbHref} class="underline-offset-4 hover:underline">{breadcrumbLabel}</a>
                <span class="px-1 text-slate-500">/</span>
                <span class="underline decoration-slate-500 underline-offset-4">{pathLabel}</span>
            </p>
            <h1 class="text-4xl font-semibold text-slate-100 md:text-5xl">{pageTitle}</h1>
            {
                subtitle && (
                    <p class="text-lg text-slate-300">
                        {subtitle}
                    </p>
                )
            }

            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                {
                    intro && (
                        <p class="max-w-3xl text-base leading-7 text-slate-300">
                            {intro}
                        </p>
                    )
                }
                {
                    codeHref && (
                        <a
                            href={codeHref}
                            class="inline-flex h-fit items-center justify-center rounded-md border border-cyan-400/70 px-4 py-2 text-sm font-medium text-cyan-300 transition-colors hover:border-cyan-300 hover:text-cyan-200"
                            target="_blank"
                            rel="noreferrer"
                        >
                            {codeLabel}
                        </a>
                    )
                }
            </div>

            <slot name="hero" />
        </header>

        <slot />
    </article>
</BaseLayout>
